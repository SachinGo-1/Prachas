# Database (SQLite for dev; swap for a PostgreSQL URL in prod)
DATABASE_URL="file:./dev.db"

# NextAuth
NEXTAUTH_SECRET="your-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# SMTP (contact + application notifications). Leave blank to log emails to console in dev.
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"

# Address that receives contact-form and job-application notifications
ADMIN_EMAIL="admin@prachas.com"
