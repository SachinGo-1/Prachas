# Database (SQLite for dev; swap for a PostgreSQL URL in prod)
DATABASE_URL="file:./dev.db"

# NextAuth — generate a secret with: openssl rand -base64 32
NEXTAUTH_SECRET="replace-with-a-random-32-char-string"
NEXTAUTH_URL="http://localhost:3000"

# SMTP (contact-form + application notifications).
# Leave SMTP_HOST/USER/PASS blank to log emails to the console in dev.
# Fill them in (e.g. Gmail app password) to actually deliver mail.
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""

# Address that receives contact-form and job-application notifications
ADMIN_EMAIL="admin@prachas.com"
